
# Google Cloud Text-to-Speech credentials (Required for translation)
# Provide the absolute path to your GCP service account credentials JSON file:
GOOGLE_APPLICATION_CREDENTIALS=
# Or paste the raw JSON content of the service account file as a single line:
GOOGLE_CREDENTIALS_JSON=

# AI Model Configurations (Defaults to smaller models for faster CPU run)
WHISPER_MODEL_NAME=tiny
NLLB_MODEL_NAME=facebook/nllb-200-distilled-600M
